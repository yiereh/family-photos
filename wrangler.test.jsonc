{
	"name": "family-photos-test",
	"compatibility_date": "2026-04-04",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "family-photos-db",
			"database_id": "test"
		}
	],
	"r2_buckets": [
		{
			"bucket_name": "family-photos-bucket",
			"binding": "BUCKET"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "test"
		}
	]
}
